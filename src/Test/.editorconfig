root = false

[*.cs]
# CS8620: Argument of type cannot be used for parameter of type due to differences in the nullability of reference types
dotnet_diagnostic.CS8620.severity = none

# IDE0300: Collection initialization can be simplified
dotnet_diagnostic.IDE0300.severity = none

# CS8625: Cannot convert null literal to non-nullable reference type
dotnet_diagnostic.CS8625.severity = none

# CS8619: Nullability of reference types in value of type doesn't match target type
dotnet_diagnostic.CS8619.severity = none

# CS8600: Converting null literal or possible null value to non-nullable type
dotnet_diagnostic.CS8600.severity = none

# CA1707: Identifiers should not contain underscores — test names use MethodName_Scenario_ExpectedResult convention
dotnet_diagnostic.CA1707.severity = none