{
  "OpenTelemetry": {
    "Tracing": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Metrics":{
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Logs": {
      "Console": {
        "Enabled": true,
        "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] (trace_id={trace_id} span_id={span_id}) {Message:lj}{NewLine}{Exception}"
      },
      "Exporter": "otlp",
      "OtlpEndpoint": "http://localhost:4317"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "JwtSettings": {
    "Issuer": "https://auth.camus.com/",
    "Audience": "https://app.camus.com/",
    "ExpirationMinutes": 120
  },
  "ApiKeySettings": {
    "SecretKeyName": "XApiKey"
  },
  "SwaggerSettings": {
    "Enabled": true,
    "Versions": [
      {
        "Version": "v1",
        "Title": "Camus API v1.0 Basic Demo",
        "Description": "Demo public endpoint."
      },
      {
        "Version": "v2",
        "Title": "Camus API v2.0 Basic Security Demo",
        "Description": "Demo for private endpoints."
      }
    ],
    "SecuritySchemes": [ "Bearer", "ApiKey" ],
    "IncludeXmlComments": true,
    "EnableAnnotations": true,
    "EnableExampleFilters": true,
    "RedirectRootToSwagger": true
  },
  "CorsSettings": {
    "AllowedOrigins": [ 
      "https://localhost:7220",
      "https://127.0.0.1:7220"
     ],
    "AllowedMethods": [ "GET", "POST" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Api-Key" ],
    "ExposedHeaders": [ "Content-Type", "X-Trace-Id" ],
    "PreflightMaxAgeMinutes": 30
  },
  "AllowedHosts": "*",
  "DaprSecretProvider": {
    "BaseHost": "localhost",
    "HttpPort": "3500",
    "TimeoutSeconds": 10,
    "UseHttps": false,
    "SecretStoreName": "default-secret-store",
    "SecretNames": [ "AccessKey", "AccessSecret", "XApiKey", "RsaPrivateKeyPem" ]
  }
}
