{
  "OpenTelemetrySettings": {
    "Tracing": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Metrics": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317",
      "DisabledMetrics": [
        "http.server.request.duration",
        "http.server.active_requests"
      ],
      "DisabledMeters": [ ".infrastructure" ]
    },
    "Logs": {
      "Console": {
        "Enabled": true,
        "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] (trace_id={trace_id} span_id={span_id}) {Message:lj}{NewLine}{Exception}"
      },
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    }
  },
  "JwtSettings": {
    "Issuer": "https://auth.camus.com/",
    "Audience": "https://app.camus.com/",
    "ExpirationMinutes": 60,
    "RsaPrivateKeySecretName": "RsaPrivateKeyPem"
  },
  "ApiKeySettings": {
    "ApiKeySecretName": "XApiKey"
  },
  "SwaggerSettings": {
    "Enabled": false,
    "Versions": [
      {
        "Version": "v1",
        "Title": "Camus API v1.0 Basic Demo",
        "Description": "Demo public endpoint."
      },
      {
        "Version": "v2",
        "Title": "Camus API v2.0 Basic Security Demo",
        "Description": "Demo for private endpoints."
      }
    ],
    "SecuritySchemes": [ "Bearer", "ApiKey" ],
    "IncludeXmlComments": true,
    "EnableAnnotations": true,
    "EnableExampleFilters": true,
    "RedirectRootToSwagger": true
  },
  "CorsSettings": {
    "PolicyName": "ClientCors",
    "AllowedOrigins": [ "https://app.camus.com/" ],
    "AllowedMethods": [ "GET", "POST" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "Api-Key" ],
    "ExposedHeaders": [ "Content-Type", "Trace-Id", "Username", "Retry-After", "RateLimit-Limit", "RateLimit-Reset", "RateLimit-Policy", "RateLimit-Window" ],
    "AllowCredentials": true,
    "PreflightMaxAgeMinutes": 5
  },
  "RateLimitSettings": {
    "Policies": {
      "default": {
        "PermitLimit": 250,
        "WindowSeconds": 60
      },
      "strict": {
        "PermitLimit": 50,
        "WindowSeconds": 60
      },
      "relaxed": {
        "PermitLimit": 500,
        "WindowSeconds": 60
      }
    },
    "ExemptPaths": [ "/health", "/ready", "/alive", "/swagger" ]
  },
  "DataPersistenceSettings": {
    "Provider": "InMemory"
  },
  "InMemoryModelSettings": {
    "Roles": [
      {
        "Name": "Admin",
        "Permissions": [ "token.create", "api.read", "api.write" ]
      },
      {
        "Name": "ReadWrite",
        "Permissions": [ "api.read", "api.write" ]
      },
      {
        "Name": "ReadOnly",
        "Permissions": [ "api.read" ]
      }
    ],
    "Users": [
      {
        "UsernameSecretName": "AdminUser",
        "PasswordSecretName": "AdminSecret",
        "Roles": [ "Admin" ]
      },
      {
        "UsernameSecretName": "ClientAppUser",
        "PasswordSecretName": "ClientAppSecret",
        "Roles": [ "ReadWrite" ]
      }
    ],
    "ApiInfos": [
      {
        "Name": "Camus API IM - 1.0 Release",
        "Version": "1.0",
        "Status": "Available",
        "Features": [
          "Basic API Information",
          "Public Endpoints",
          "Basic Observability"
        ]
      },
      {
        "Name": "Camus API IM - 2.0 Beta",
        "Version": "2.0",
        "Status": "Beta",
        "Features": [
          "Authentication (JWT & API Key)",
          "Authorization (Role-based)",
          "API Versioning",
          "Observability (OpenTelemetry)",
          "Rate Limiting (Multiple policies)",
          "Swagger/OpenAPI Documentation",
          "Secret Management (Dapr)",
          "Error Handling",
          "CORS Support",
          "Health Checks"
        ]
      }
    ]
  },
  "DatabaseSettings": {
    "Host": "localhost",
    "Port": 5432,
    "Database": "camus",
    "UserSecretName": "DBUser",
    "PasswordSecretName": "DBSecret",
    "AdditionalParameters": "Timeout=30;Pooling=true;MinPoolSize=1;MaxPoolSize=20;SslMode=Require"
  },
  "DBUpSettings": {
    "Enabled": false,
    "AdminSecretName": "DBMigrationsUser",
    "PasswordSecretName": "DBMigrationsSecret"
  },
  "DaprSecretProviderSettings": {
    "BaseHost": "localhost",
    "HttpPort": "3500",
    "TimeoutSeconds": 30,
    "SecretStoreName": "default-secret-store",
    "SecretNames": [
      "AdminUser",
      "AdminSecret",
      "ClientAppUser",
      "ClientAppSecret",
      "XApiKey",
      "RsaPrivateKeyPem",
      "DBMigrationsUser",
      "DBMigrationsSecret",
      "DBUser",
      "DBSecret"
    ]
  },
  "ErrorHandlingSettings": {
    "AdditionalRules": [
      {
        "Type": "InvalidOperationException",
        "ErrorCode": "invalid_operation"
      },
      {
        "Pattern": "database.*connection",
        "ErrorCode": "database_connection_error"
      },
      {
        "Type": "TimeoutException",
        "Pattern": "operation.*timed out",
        "ErrorCode": "operation_timeout"
      }
    ]
  },
  "AllowedHosts": "api.camus.com;www.camus.com",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
}
