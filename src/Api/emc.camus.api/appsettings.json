{
  "OpenTelemetry": {
    "Tracing": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Metrics": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317",
      "DisabledMetrics": [
        "http.server.request.duration",
        "http.server.active_requests"
      ],
      "DisabledMeters": [ ".infrastructure" ]
    },
    "Logs": {
      "Console": {
        "Enabled": true,
        "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] (trace_id={trace_id} span_id={span_id}) {Message:lj}{NewLine}{Exception}"
      },
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "JwtSettings": {
    "Issuer": "https://auth.camus.com/",
    "Audience": "https://app.camus.com/",
    "ExpirationMinutes": 60,
    "RsaPrivateKeySecretName": "RsaPrivateKeyPem"
  },
  "ApiKeySettings": {
    "ApiKeySecretName": "XApiKey"
  },
  "SwaggerSettings": {
    "Enabled": false,
    "Versions": [
      {
        "Version": "v1",
        "Title": "Camus API v1.0 Basic Demo",
        "Description": "Demo public endpoint."
      },
      {
        "Version": "v2",
        "Title": "Camus API v2.0 Basic Security Demo",
        "Description": "Demo for private endpoints."
      }
    ],
    "SecuritySchemes": [ "Bearer", "ApiKey" ],
    "IncludeXmlComments": true,
    "EnableAnnotations": true,
    "EnableExampleFilters": true,
    "RedirectRootToSwagger": true
  },
  "CorsSettings": {
    "PolicyName": "ClientCors",
    "AllowedOrigins": [ "https://app.camus.com/" ],
    "AllowedMethods": [ "GET", "POST" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Api-Key" ],
    "ExposedHeaders": [ "Content-Type", "X-Trace-Id", "Retry-After", "RateLimit-Limit", "RateLimit-Reset", "X-RateLimit-Policy", "X-RateLimit-Window" ],
    "AllowCredentials": true,
    "PreflightMaxAgeMinutes": 5
  },
  "RateLimitSettings": {
    "Policies": {
      "default": {
        "PermitLimit": 250,
        "WindowSeconds": 60
      },
      "strict": {
        "PermitLimit": 50,
        "WindowSeconds": 60
      },
      "relaxed": {
        "PermitLimit": 500,
        "WindowSeconds": 60
      }
    },
    "ExemptPaths": [ "/health", "/ready", "/alive", "/swagger" ]
  },
  "AllowedHosts": "api.camus.com;www.camus.com",
  "AppDataSettings": {
    "Provider": "InMemory",
    "InMemory": {
      "ApiInfos": [
        {
          "Name": "Camus API - 1.0 Release",
          "Version": "1.0",
          "Status": "Available",
          "Features": [
            "Basic API Information",
            "Public Endpoints",
            "Basic Observability"
          ]
        },
        {
          "Name": "Camus API - 2.0 Release",
          "Version": "2.0",
          "Status": "Available",
          "Features": [
            "Authentication (JWT & API Key)",
            "Authorization (Role-based)",
            "API Versioning",
            "Observability (OpenTelemetry)",
            "Rate Limiting (Multiple policies)",
            "Swagger/OpenAPI Documentation",
            "Secret Management (Dapr)",
            "Error Handling",
            "CORS Support",
            "Health Checks"
          ]
        }
      ]
    },
    "Database": {
      "Provider": "PostgreSQL",
      "ConnectionString": "Host=localhost;Port=5432;Database=camus_appdata;Username=postgres;Password=postgres"
    }
  },
  "Authorization": {
    "Provider": "InMemory",
    "InMemory": {
      "Roles": [
        {
          "Name": "Admin",
          "Permissions": [ "token.create", "api.read", "api.write" ]
        },
        {
          "Name": "ReadWrite",
          "Permissions": [ "api.read", "api.write" ]
        },
        {
          "Name": "ReadOnly",
          "Permissions": [ "api.read" ]
        }
      ],
      "Users": [
        {
          "UsernameSecretName": "AdminUser",
          "PasswordSecretName": "AdminUserPassword",
          "Roles": [ "Admin" ]
        },
        {
          "UsernameSecretName": "ClientApp",
          "PasswordSecretName": "ClientAppPassword",
          "Roles": [ "ReadWrite" ]
        }
      ]
    },
    "Database": {
      "Provider": "PostgreSQL",
      "ConnectionString": "Host=localhost;Port=5432;Database=camus;Username=postgres;Password=postgres"
    }
  },
  "DaprSecretProvider": {
    "BaseHost": "localhost",
    "HttpPort": "3500",
    "TimeoutSeconds": 30,
    "SecretStoreName": "default-secret-store",
    "SecretNames": [ "AdminUser", "AdminUserPassword", "ClientApp", "ClientAppPassword", "XApiKey", "RsaPrivateKeyPem" ]
  },
  "ErrorHandlingSettings": {
    "AdditionalRules": [
      {
        "Type": "InvalidOperationException",
        "ErrorCode": "invalid_operation"
      },
      {
        "Pattern": "database.*connection",
        "ErrorCode": "database_connection_error"
      },
      {
        "Type": "TimeoutException",
        "Pattern": "operation.*timed out",
        "ErrorCode": "operation_timeout"
      }
    ]
  }
}
