{
  "OpenTelemetry": {
    "Tracing": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Metrics": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Logs": {
      "Console": {
        "Enabled": true,
        "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] (trace_id={trace_id} span_id={span_id}) {Message:lj}{NewLine}{Exception}"
      },
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "OpenTelemetry": "Information"
    }
  },
  "JwtSettings": {
    "Issuer": "https://auth.camuslabs.com/",
    "Audience": "https://app.camuslabs.com/",
    "ExpirationMinutes": 60
  },
  "CorsSettings": {
    "AllowedOrigins": [ "https://app.camuslabs.com/" ],
    "AllowedMethods": [ "GET", "POST" ],
    "AllowedHeaders": [ "Content-Type", "Authorization" ],
    "ExposedHeaders": [ "Authorization", "Content-Type", "X-Trace-Id" ],
    "PreflightMaxAgeMinutes": 5
  },
  "AllowedHosts": "api.camuslabs.com;www.camuslabs.com",
  "DaprSecretProvider": {
    "BaseHost": "localhost",
    "HttpPort": "3500",
    "TimeoutSeconds": 30,
    "UseHttps": false,
    "SecretStoreName": "default-secret-store",
    "SecretNames": [ "AccessKey", "AccessSecret", "XApiKey" ]
  }
}
