{
  "OpenTelemetry": {
    "Tracing": {
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Metrics":{
      "Exporter": "none",
      "OtlpEndpoint": "http://localhost:4317"
    },
    "Logs": {
      "Console": {
        "Enabled": true,
        "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] (trace_id={trace_id} span_id={span_id}) {Message:lj}{NewLine}{Exception}"
      },
      "Exporter": "otlp",
      "OtlpEndpoint": "http://localhost:4317"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "Issuer": "https://auth.camuslabs.com/",
    "Audience": "https://app.camuslabs.com/",
    "ExpirationMinutes": 120
  },
  "CorsSettings": {
    "AllowedOrigins": [ 
      "http://localhost:5045",
      "https://localhost:7220",
      "http://127.0.0.1:5000",
      "https://127.0.0.1:7220"
     ],
    "AllowedMethods": [ "GET", "POST" ],
    "AllowedHeaders": [ "Content-Type", "Authorization" ],
    "ExposedHeaders": [ "Authorization", "Content-Type", "X-Trace-Id" ],
    "PreflightMaxAgeMinutes": 30
  },
  "AllowedHosts": "*",
  "DaprSecretProvider": {
    "BaseHost": "localhost",
    "HttpPort": "3500",
    "TimeoutSeconds": 10,
    "UseHttps": false,
    "SecretStoreName": "default-secret-store",
    "SecretNames": [ "AccessKey", "AccessSecret", "XApiKey", "RsaPrivateKeyPem" ]
  }
}
