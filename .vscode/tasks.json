{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet build src/CamusApp.sln /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "type": "shell",
            "command": "dotnet test src/CamusApp.sln /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test-with-coverage",
            "type": "shell",
            "command": "dotnet test src/CamusApp.sln --collect:\"XPlat Code Coverage\" /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test-coverage-report",
            "type": "shell",
            "command": "reportgenerator -reports:\"src/Test/**/TestResults/**/coverage.cobertura.xml\" -targetdir:\"coveragereport\" -reporttypes:Html && open coveragereport/index.html",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "run-api",
            "type": "shell",
            "command": "dotnet run --project src/Api/emc.camus.api/emc.camus.api.csproj /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch-api",
            "type": "shell",
            "command": "dotnet watch --project src/Api/emc.camus.api/emc.camus.api.csproj run /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": "$msCompile",
            "group": "none"
        },
        {
            "label": "publish-api",
            "type": "shell",
            "command": "dotnet publish src/Api/emc.camus.api/emc.camus.api.csproj -c Release /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run-dapr-sidecar",
            "type": "shell",
            "command": "dapr run --app-id camus-app --dapr-http-port 3500 --dapr-grpc-port 50001 --resources-path .",
            "options": {
                "cwd": "${workspaceFolder}/src/Infrastructure/dapr"
            },
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "docker-compose-up-dev",
            "type": "shell",
            "command": "docker-compose -f docker-compose.dev.yml up --build -d",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "docker-compose-up-observability",
            "type": "shell",
            "command": "docker-compose -f docker-compose.dev.yml up postgres otel-collector jaeger loki prometheus grafana -d",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "docker-compose-down",
            "type": "shell",
            "command": "docker-compose -f docker-compose.dev.yml down",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": []
        }
    ]
}