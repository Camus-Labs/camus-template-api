{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet build src/CamusApp.sln /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "type": "shell",
            "command": "dotnet test src/CamusApp.sln /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run-api",
            "type": "shell",
            "command": "dotnet run --project src/Api/emc.main.api/emc.camus.main.api.csproj /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch-api",
            "type": "shell",
            "command": "dotnet watch --project src/Api/emc.main.api/emc.camus.main.api.csproj run -- /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": "$msCompile",
            "group": "none"
        },
        {
            "label": "publish-api",
            "type": "shell",
            "command": "dotnet publish src/Api/emc.main.api/emc.camus.main.api.csproj -c Release /p:GeneratePullPaths=true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run-dapr-sidecar",
            "type": "shell",
            "command": "dapr run --app-id camus-app --dapr-http-port 3500 --dapr-grpc-port 50001 --resources-path .",
            "options": {
                "cwd": "${workspaceFolder}/src/Adapters/emc.adapterdapr.components"
            },
            "group": "none",
            "problemMatcher": []
        }
    ]
}