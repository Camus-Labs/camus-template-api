{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch API (Host)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/Api/emc.main.api/bin/Debug/net9.0/emc.camus.main.api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Api/emc.main.api",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": ".NET Attach to Container",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickRemoteProcess}",
            "pipeTransport": {
                "pipeCwd": "${workspaceFolder}",
                "pipeProgram": "docker",
                "pipeArgs": ["exec", "-i", "camus-api-dev"],
                "debuggerPath": "/vsdbg/vsdbg",
                "quoteArgs": false
            },
            "sourceFileMap": {
                "/src": "${workspaceFolder}/src"
            }
        }
    ]
}